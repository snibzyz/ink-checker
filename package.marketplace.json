{
  "name": "kunpeng-checker",
  "displayName": "INK CHECKER",
  "description": "Word and writing consistency checker for Thai text",
  "version": "0.0.8",
  "publisher": "kunpeng-dev",
  "icon": "inkrealm-logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/snibzyz/ink-checker.git"
  },
  "homepage": "https://github.com/snibzyz/ink-checker",
  "bugs": {
    "url": "https://github.com/snibzyz/ink-checker/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "thai",
    "writing",
    "proofreading",
    "editor",
    "checker"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ink-checker.openWordList",
        "title": "INK CHECKER: เปิดจัดการรายการคำ",
        "icon": "$(list-unordered)"
      },
      {
        "command": "ink-checker.openSettings",
        "title": "INK CHECKER: เปิด Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "ink-checker.toggleChecker",
        "title": "INK CHECKER: เปิด/ปิดการตรวจสอบ",
        "icon": "$(eye)"
      }
    ],
    "configuration": [
      {
        "title": "INK CHECKER",
        "properties": {
          "inkChecker.enabled": {
            "type": "boolean",
            "default": true,
            "description": "เปิดหรือปิดการตรวจสอบคำทั้งหมด"
          },
          "inkChecker.customWords": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": ["นาย", "แก", "ฉัน"],
            "description": "รายการคำที่ต้องการตรวจสอบ"
          },
          "inkChecker.wordGroups": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": ["ข้า, ฉัน, เธอ, คุณ, เจ้า"],
            "description": "กลุ่มคำที่สามารถสลับกันได้ โดยคั่นคำในแต่ละกลุ่มด้วยเครื่องหมายจุลภาค"
          }
        }
      },
      {
        "title": "INK CHECKER Detection Rules",
        "properties": {
          "inkChecker.checkEnglish": {
            "type": "boolean",
            "default": false,
            "description": "ตรวจหาคำหรือข้อความภาษาอังกฤษ"
          },
          "inkChecker.checkNumbers": {
            "type": "boolean",
            "default": false,
            "description": "ตรวจหาตัวเลข"
          },
          "inkChecker.checkForeignLanguages": {
            "type": "boolean",
            "default": false,
            "description": "ตรวจหาภาษาต่างประเทศอื่นที่ไม่ใช่ภาษาไทย"
          },
          "inkChecker.checkUnclosedFancyQuotes": {
            "type": "boolean",
            "default": true,
            "description": "ตรวจหาอัญประกาศโค้งที่เปิดแล้วไม่ปิด"
          },
          "inkChecker.checkUnclosedDoubleQuotes": {
            "type": "boolean",
            "default": false,
            "description": "ตรวจหาเครื่องหมายอัญประกาศคู่ที่เปิดแล้วไม่ปิด"
          },
          "inkChecker.checkUnclosedSingleQuotes": {
            "type": "boolean",
            "default": false,
            "description": "ตรวจหาเครื่องหมายอัญประกาศเดี่ยวที่เปิดแล้วไม่ปิด"
          },
          "inkChecker.checkUnclosedParentheses": {
            "type": "boolean",
            "default": false,
            "description": "ตรวจหาวงเล็บที่เปิดแล้วไม่ปิด"
          },
          "inkChecker.checkUnclosedBrackets": {
            "type": "boolean",
            "default": false,
            "description": "ตรวจหาวงเล็บเหลี่ยมที่เปิดแล้วไม่ปิด"
          }
        }
      },
      {
        "title": "INK CHECKER Highlight Colors",
        "properties": {
          "inkChecker.customWordsColor": {
            "type": "string",
            "default": "rgba(255, 229, 100, 0.6)",
            "description": "สีไฮไลต์สำหรับรายการคำที่กำหนดเอง"
          },
          "inkChecker.languageAndNumberColor": {
            "type": "string",
            "default": "rgba(173, 216, 230, 0.5)",
            "description": "สีไฮไลต์สำหรับภาษาต่างประเทศ ภาษาอังกฤษ และตัวเลข"
          },
          "inkChecker.unbalancedCharactersColor": {
            "type": "string",
            "default": "rgba(255, 100, 100, 0.4)",
            "description": "สีไฮไลต์สำหรับวงเล็บหรือเครื่องหมายคำพูดที่เปิดแล้วไม่ปิด"
          }
        }
      }
    ]
  },
  "scripts": {
    "use:marketplace": "node scripts/use-manifest.cjs marketplace",
    "use:openvsx": "node scripts/use-manifest.cjs openvsx",
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "22.x",
    "typescript": "^5.9.3"
  }
}
