# Exclude non-publish and local-only files from the VSIX

# Secrets / tokens
tokens.env
user.json

# Docs only for manual distribution (do not ship to Marketplace)
example-settings.json
วิธีติดตั้ง.txt
README-settings.md
PUBLISH-GUIDE.md
