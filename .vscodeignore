# Source and tests (publish compiled JS from out/ only)
src/**
**/*.ts
out/test/**
src/test/**

# Build artifacts not needed at runtime
**/*.map
node_modules/**

# Dev configs
.vscode/**
.vscode-test.mjs
.eslint*
eslint.config.mjs
package-lock.json
tsconfig.json

# OS junk
**/.DS_Store
**/Thumbs.db

